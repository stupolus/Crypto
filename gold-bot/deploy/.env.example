# Скопировать в deploy/.env на VPS и заполнить. Файл .env в .gitignore.
# Если переменные пустые — Telegram-нотификации отключены, runner остаётся
# в лог. Никаких ключей бирж в этом файле быть не должно: paper-runner
# приватные методы вообще не вызывает (CLAUDE.md §6, plan 06).

GOLDBOT_TG_TOKEN=
GOLDBOT_TG_CHAT_ID=
