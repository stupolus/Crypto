# Пример переменных окружения для gold-bot. Реальный .env НЕ коммитится
# (см. .gitignore). На VPS: права 600, ключи только trading+read, без вывода.

# BingX VST (demo / виртуальные средства) — безопасный дефолт
BINGX_VST_API_KEY=
BINGX_VST_API_SECRET=

# BingX live (используется ТОЛЬКО при BINGX_LIVE=1; по умолчанию не трогаем)
BINGX_LIVE=
BINGX_API_KEY=
BINGX_API_SECRET=

# Bybit testnet (BYBIT_TESTNET=1) или live
BYBIT_TESTNET=
BYBIT_API_KEY=
BYBIT_API_SECRET=

# Bybit testnet для integration-теста (pytest -m integration)
BYBIT_TESTNET_API_KEY=
BYBIT_TESTNET_API_SECRET=
