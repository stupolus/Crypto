# EditorConfig — консистентный стиль между IDE (VS Code, PyCharm, vim, ...).
# Подробнее: https://editorconfig.org

root = true

[*]
end_of_line = lf
insert_final_newline = true
charset = utf-8
trim_trailing_whitespace = true

[*.py]
indent_style = space
indent_size = 4
max_line_length = 100

[*.{yml,yaml}]
indent_style = space
indent_size = 2

[*.{md,markdown}]
trim_trailing_whitespace = false  # markdown сохраняет пробелы для line-breaks

[*.{json,toml}]
indent_style = space
indent_size = 2

[Makefile]
indent_style = tab
