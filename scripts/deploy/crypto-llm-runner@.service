[Unit]
Description=Crypto bot LLM runner (Phase E) — %i (BingX VST/live)
After=network-online.target
Wants=network-online.target
StartLimitInterval=300
StartLimitBurst=5

[Service]
Type=simple
User=crypto
Group=crypto
WorkingDirectory=/opt/crypto
EnvironmentFile=/etc/crypto/.env
ExecStart=/opt/crypto/.venv/bin/python -m runners.llm_runner \
    --strategy btc_breakout \
    --symbol %i \
    --interval 15m \
    --warmup-candles 100 \
    --metrics-file /var/lib/crypto/llm-%i-metrics.jsonl \
    --journal-db /var/lib/crypto/llm-%i.sqlite \
    --outcomes-db /var/lib/crypto/llm-%i-outcomes.sqlite \
    --heartbeat-file /var/lib/crypto/llm-%i.heartbeat \
    --log-level INFO

# Авто-рестарт при крэше (но НЕ при ручном stop)
Restart=on-failure
RestartSec=10s

# Лимит: 5 рестартов за 5 минут. Если падает чаще — systemd прекращает,
# unit переходит в 'failed'. UptimeRobot шлёт алерт по heartbeat-файлу
# (mtime > 5 min → unhealthy).

# Логи в journald
StandardOutput=journal
StandardError=journal
SyslogIdentifier=crypto-llm-%i

# Безопасность: read-only / минимум прав
NoNewPrivileges=true
ProtectSystem=strict
ReadWritePaths=/var/lib/crypto
ProtectHome=true
PrivateTmp=true
ProtectKernelTunables=true
ProtectKernelModules=true
ProtectControlGroups=true
RestrictAddressFamilies=AF_INET AF_INET6 AF_UNIX
RestrictNamespaces=true
LockPersonality=true
MemoryDenyWriteExecute=true
RestrictRealtime=true

[Install]
WantedBy=multi-user.target
