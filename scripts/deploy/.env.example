# Crypto bot — environment template.
# Скопировать в /etc/crypto/.env, заполнить, chmod 600.
#
# sudo mkdir -p /etc/crypto
# sudo cp scripts/deploy/.env.example /etc/crypto/.env
# sudo nano /etc/crypto/.env
# sudo chmod 600 /etc/crypto/.env
# sudo chown root:docker /etc/crypto/.env

# ── BingX API ─────────────────────────────────────────────────────────────
# VST = testnet (виртуальные деньги). Для D3 demo.
# Получить в BingX → API Management → Create.
BINGX_ENV=vst
BINGX_VST_API_KEY=
BINGX_VST_API_SECRET=

# Live = реальные деньги. Заполнить ТОЛЬКО после 4+ недель успешного VST.
# Права API: только Trading (без Withdraw!), IP whitelist на IP VPS.
# BINGX_LIVE_API_KEY=
# BINGX_LIVE_API_SECRET=

# ── Telegram алерты (опционально, рекомендуется) ──────────────────────────
# Получить:
#   1. Telegram → @BotFather → /newbot → TOKEN
#   2. Открыть чат с ботом, написать сообщение
#   3. https://api.telegram.org/bot<TOKEN>/getUpdates → chat.id
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
