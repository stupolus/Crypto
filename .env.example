# BingX API keys — никогда не коммитить реальный .env (см. .gitignore).
# Создать demo-ключи: https://bingx.com/en/accounts/api → Demo Trading.
# Правила безопасности (бизнес/риск-профиль.md, CLAUDE.md):
#   - только торговые права, БЕЗ вывода средств,
#   - IP whitelist обязателен (VPS-IP и/или рабочий IP),
#   - VST (demo) и live — разные пары ключей.

# Окружение для адаптера: vst (demo) | live.
# Для фаз 0.C–0.D работаем только на vst.
BINGX_ENV=vst

# VST (demo trading) — для фазы 0.C smoke + integration.
BINGX_VST_API_KEY=
BINGX_VST_API_SECRET=

# Live (реальные деньги) — НЕ заполнять, пока не пройдены 4+ недели demo
# и не получено явное подтверждение пользователя (правила CLAUDE.md).
BINGX_LIVE_API_KEY=
BINGX_LIVE_API_SECRET=

# Coinglass API key — для liquidation/OI/CVD/funding (бэктест + live).
# Тариф HOBBYIST: 4h≤180д, 6h/8h/12h≤360д; OI через /open-interest/history.
COINGLASS_API_KEY=

# Telegram-алерты (опционально). Если оба пусты — бот шлёт в stdout,
# НЕ падает. Бот: @BotFather → /newbot → токен. chat_id: добавь бота в
# чат/группу и возьми id (напр. через @userinfobot или getUpdates).
# Рекомендуется ОТДЕЛЬНЫЙ чат под бота «трейдер».
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# CryptoQuant API key — КАНДИДАТ на будущий источник данных (глубже
# истории, чем Coinglass HOBBYIST). Пока НЕ интегрирован в контур —
# задел на отдельную фазу. Текущий demo на нём не зависит.
CRYPTOQUANT_API_KEY=

# Hack B (план 01 §6j): на shared VST-аккаунте чужие боты контаминируют
# equity. Этот baseline (в VST/USDT) используется RiskEngine и отчётом
# как «фиксированный депозит трейдера», просадка считается от него.
# Снимется с переходом на отдельный VST-аккаунт под трейдер-бота.
# По трейдер/правила/риск-профиль.md стартовый депозит = 10000.
TRADER_EQUITY_BASELINE=10000
